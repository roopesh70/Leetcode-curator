RECIPIENT_EMAIL=your-email@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-gmail-address@gmail.com
SMTP_PASS=your-gmail-app-password

# Optional. If set, the script asks AI to personalize the selection from the
# vetted problem bank. Without it, the script still sends a good deterministic set.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
